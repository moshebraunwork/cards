<!doctype html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>Design No. <%= THEMES[themeId].no %> — <%= THEMES[themeId].name %> | <%= BRAND %></title>
  <meta name="robots" content="noindex, nofollow">
</head>
<body class="page-editor">
  <header class="site-header editor-header">
    <a class="btn btn-quiet btn-back" href="/#designs">← Back to gallery</a>
    <div class="editor-title">
      <span class="wordmark-small"><%= BRAND %>-<%= THEMES[themeId].no %></span>
      <span class="design-tag"><%= THEMES[themeId].name %></span>
    </div>
    <span class="header-spacer"></span>
  </header>

  <main class="editor-layout">
    <section class="editor-preview">
      <div class="preview-frame" id="cardNode">
        <%- include('partials/card', { d: data, themeId }) %>
      </div>
      <button class="btn btn-gold btn-big btn-download" id="downloadBtn">⬇ Download your card — free</button>
      <p class="save-note">Your edits are saved in this browser. Come back to this page any time to continue.</p>
    </section>

    <section class="editor-form">
      <h1 class="form-title">Personalize</h1>
      <p class="form-sub">Every field updates the preview instantly.</p>

      <label class="field">
        <span>Simcha</span>
        <select id="f-eventType">
          <% for (const [id, ev] of Object.entries(EVENTS)) { %>
            <option value="<%= id %>" <%= data.eventType === id ? 'selected' : '' %>><%= ev.label %></option>
          <% } %>
        </select>
      </label>

      <label class="field">
        <span>Invitation line</span>
        <textarea id="f-inviteLine" rows="2" maxlength="200"><%= data.inviteLine %></textarea>
      </label>

      <label class="field">
        <span>Name of the baal simcha</span>
        <input id="f-honoree" maxlength="120" value="<%= data.honoree %>" placeholder="Yosef Chaim">
      </label>

      <label class="field">
        <span>Hosted by</span>
        <input id="f-hostsLine" maxlength="160" value="<%= data.hostsLine %>" placeholder="Dovid &amp; Miriam Goldberg">
      </label>

      <div class="field-row">
        <label class="field">
          <span>Date</span>
          <input id="f-date" type="date" value="<%= data.date %>">
        </label>
        <label class="field">
          <span>Time</span>
          <input id="f-time" maxlength="60" value="<%= data.time %>" placeholder="7:00 PM">
        </label>
      </div>

      <label class="check">
        <input id="f-afterSunset" type="checkbox" <%= data.afterSunset ? 'checked' : '' %>>
        <span>Event is after shkiah (advance the Hebrew date)</span>
      </label>

      <label class="check">
        <input id="f-bsd" type="checkbox" <%= data.bsd ? 'checked' : '' %>>
        <span>Show בס״ד</span>
      </label>

      <label class="field">
        <span>Venue</span>
        <input id="f-venue" maxlength="120" value="<%= data.venue %>" placeholder="Ateres Chana Hall">
      </label>

      <label class="field">
        <span>Address</span>
        <input id="f-address" maxlength="200" value="<%= data.address %>" placeholder="221 Maple Ave, Monsey, NY">
      </label>

      <label class="field">
        <span>Additional details</span>
        <textarea id="f-note" rows="2" maxlength="400" placeholder="Kabbolas Ponim 6:30 · Seuda to follow"><%= data.note %></textarea>
      </label>

      <label class="field">
        <span>Sign-off <em>(optional)</em></span>
        <input id="f-signoff" maxlength="120" value="<%= data.signoff %>" placeholder="The Goldberg Family">
      </label>

      <div class="field">
        <span class="field-label">Design</span>
        <div class="theme-pills" id="themePills">
          <% for (const [id, t] of Object.entries(THEMES)) { %>
            <button type="button" class="pill<%= id === themeId ? ' active' : '' %>" data-themeid="<%= id %>" title="<%= t.name %>">
              <span class="pill-swatch" data-swatch="<%= id %>"></span> <%= t.no %>
            </button>
          <% } %>
        </div>
      </div>

      <button class="btn btn-quiet" id="resetBtn">Reset this design</button>
    </section>
  </main>

  <script>
    window.__CARD__ = {
      themeId: <%- JSON.stringify(themeId) %>,
      data: <%- JSON.stringify(data) %>,
      eventDefaults: <%- JSON.stringify(Object.fromEntries(Object.entries(EVENTS).map(([k, v]) => [k, v.invite]))) %>
    };
  </script>
  <script src="<%= asset('/vendor/html2canvas.min.js') %>"></script>
  <script src="<%= asset('/js/editor.js') %>"></script>
</body>
</html>
